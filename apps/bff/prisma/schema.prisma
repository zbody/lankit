generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  parentId  String?  @map("parent_id")
  parent    Organization? @relation("OrgTree", fields: [parentId], references: [id])
  children  Organization[] @relation("OrgTree")
  users     User[]
  sort      Int      @default(0)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organizations")
  @@index([parentId])
  @@index([deletedAt])
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  organizationId String?  @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  roles          UserRole[]
  menus          UserMenu[]
  isActive       Boolean  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  deletedAt      DateTime? @map("deleted_at")
  oauthAccounts  UserOAuth[]
  resetTokens    PasswordResetToken[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("users")
  @@index([organizationId])
  @@index([email])
  @@index([deletedAt])
}

model Role {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  menus       RoleMenu[]
  users       UserRole[]
  isSystem    Boolean  @default(false) @map("is_system")
  sort        Int      @default(0)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
  @@index([deletedAt])
}

model Menu {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  parentId    String?  @map("parent_id")
  parent      Menu?    @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]   @relation("MenuTree")
  path        String?
  component   String?
  icon        String?
  type        MenuType @default(MENU)
  permission  String?
  sort        Int      @default(0)
  isVisible   Boolean  @default(true) @map("is_visible")
  isCache     Boolean  @default(false) @map("is_cache")
  deletedAt   DateTime? @map("deleted_at")
  roles       RoleMenu[]
  users       UserMenu[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("menus")
  @@index([parentId])
  @@index([code])
  @@index([deletedAt])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@map("user_roles")
  @@index([userId])
  @@index([roleId])
}

model RoleMenu {
  id        String   @id @default(cuid())
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menuId    String   @map("menu_id")
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roleId, menuId])
  @@map("role_menus")
  @@index([roleId])
  @@index([menuId])
}

model UserMenu {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuId    String   @map("menu_id")
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, menuId])
  @@map("user_menus")
  @@index([userId])
  @@index([menuId])
}

enum MenuType {
  DIRECTORY // 目录
  MENU      // 菜单
  BUTTON    // 按钮/权限点
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")
  action     String   // CREATE/UPDATE/DELETE
  entity     String   // User/Org/Role/Menu
  entityId   String?  @map("entity_id")
  oldValues  Json?  @map("old_values")
  newValues  Json?  @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([userId])
  @@index([createdAt])
  @@index([entity])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      NotificationType @default(INFO)
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?  @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
  @@index([userId, isRead])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?  @map("description")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("system_settings")
}

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  success    Boolean
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  reason     String?  // 失败原因
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("login_attempts")
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model OperationLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  userName     String?  @map("user_name")
  action       String   // CREATE/UPDATE/DELETE
  entity       String   // User/Org/Role/Menu
  ipAddress    String?  @map("ip_address")
  duration     Int      // 操作耗时（毫秒）
  success      Boolean  @default(true)
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("operation_logs")
  @@index([userId])
  @@index([createdAt])
  @@index([entity])
}

enum DictKind {
  STRING
  NUMBER
  BOOLEAN
}

model DictType {
  id        String    @id @default(cuid())
  name      String    // 字典名称
  code      String    @unique // 字典编码
  kind      DictKind  @default(STRING)
  sort      Int       @default(0)
  status    Boolean   @default(true)
  remark    String?
  items     DictData[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("dict_types")
}

model DictData {
  id         String   @id @default(cuid())
  dictTypeId String   @map("dict_type_id")
  dictType   DictType @relation(fields: [dictTypeId], references: [id], onDelete: Cascade)
  label      String
  value      String
  color      String?
  sort       Int      @default(0)
  status     Boolean  @default(true)
  remark     String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("dict_data")
  @@index([dictTypeId])
}

model FileRecord {
  id           String   @id @default(cuid())
  originalName String   @map("original_name")
  fileName     String   @map("file_name")
  ext          String?
  mimeType     String   @map("mime_type")
  size         Int
  path         String
  url          String
  uploadedBy   String?  @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("file_records")
  @@index([uploadedBy])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String   // 公告标题
  content   String   // 公告内容（支持 HTML）
  level     String   @default("INFO") // INFO / WARNING / IMPORTANT
  status    Boolean  @default(true)   // true=已发布 false=草稿
  sort      Int      @default(0)
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("announcements")
  @@index([status, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String    // 密钥名称
  key        String    @unique // 密钥标识（如 lk_xxxx）
  secretHash String    @map("secret_hash") // sha256(secret)
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  status     Boolean   @default(true)
  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("api_keys")
  @@index([key])
}

model EmailLog {
  id         String   @id @default(cuid())
  to         String
  subject    String
  content    String
  status     String   @default("PENDING") // PENDING / SUCCESS / FAILED
  errorMsg   String?  @map("error_msg")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("email_logs")
  @@index([status, createdAt])
}

model ScheduledTask {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?
  cronExpr     String   @map("cron_expr")
  handler      String   // 任务处理函数标识
  params       String?  // JSON 参数字符串
  status       Boolean  @default(true) // true=启用 false=停用
  lastRunAt    DateTime? @map("last_run_at")
  lastResult   String?  @map("last_result")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("scheduled_tasks")
  @@index([code])
}

model UserMfa {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  secret      String   // TOTP secret
  enabled     Boolean  @default(false)
  method      String   @default("TOTP") // TOTP / SMS / EMAIL
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_mfa")
}

model Approval {
  id         String        @id @default(cuid())
  title      String        // 审批标题
  type       String        // 审批类型（如 DELETE_USER / CHANGE_ROLE）
  status     String        @default("PENDING") // PENDING / APPROVED / REJECTED
  applicantId String       @map("applicant_id")
  content    String        // 申请内容 JSON
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  actions    ApprovalAction[]

  @@map("approvals")
  @@index([status, createdAt])
}

model ApprovalAction {
  id         String   @id @default(cuid())
  approvalId String   @map("approval_id")
  approval   Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  action     String   // APPROVED / REJECTED
  comment    String?
  operatorId String   @map("operator_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("approval_actions")
  @@index([approvalId])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sort      Int        @default(0)
  status    Boolean    @default(true)
  articles  Article[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("categories")
  @@index([parentId])
}

model Article {
  id           String    @id @default(cuid())
  title        String
  content      String
  summary      String?
  coverUrl     String?   @map("cover_url")
  categoryId   String?   @map("category_id")
  category     Category? @relation(fields: [categoryId], references: [id])
  tags         String?   // JSON array
  status       String    @default("DRAFT") // DRAFT / PUBLISHED
  isFeatured   Boolean   @default(false) @map("is_featured")
  viewCount    Int       @default(0) @map("view_count")
  seoTitle     String?   @map("seo_title")
  seoDesc      String?   @map("seo_desc")
  seoKeywords  String?   @map("seo_keywords")
  publishedAt  DateTime? @map("published_at")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("articles")
  @@index([categoryId, status])
  @@index([status, publishedAt])
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String
  content    String
  status     String   @default("UNREAD") // UNREAD / READ / REPLIED
  reply      String?
  repliedAt  DateTime? @map("replied_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("contact_messages")
  @@index([status, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
  @@index([userId])
  @@index([expiresAt])
}

model UserOAuth {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String   // github / google / wechat
  providerId String   @map("provider_id") // 第三方用户 ID
  avatarUrl  String?  @map("avatar_url")
  rawData    String?  @map("raw_data") // 原始返回数据 JSON
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("user_oauths")
  @@unique([provider, providerId])
  @@index([userId])
}
FROM node:20-alpine AS build
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

# 依赖缓存层
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY apps/h5/package.json ./apps/h5/
COPY packages/config/package.json ./packages/config/
COPY packages/shared/package.json ./packages/shared/

RUN pnpm install --frozen-lockfile

# 构建 shared
COPY packages/shared/ ./packages/shared/
RUN pnpm --filter @platform/shared exec tsc

# 构建 h5
COPY apps/h5/ ./apps/h5/
RUN pnpm --filter @platform/h5 build

# nginx 运行阶段
FROM nginx:alpine
COPY --from=build /app/apps/h5/dist /usr/share/nginx/html
COPY docker/nginx-h5.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]

# ============================================
# Lankit 全栈管理平台 - 环境变量总览
# ============================================
# 复制此文件为 .env 或各应用下的 .env.local
# cp .env.example .env

# --- PostgreSQL (Docker) ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_dev
POSTGRES_DB=platform

# --- BFF ---
BFF_PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://platform:platform_dev@localhost:5432/platform
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
REDIS_URL=redis://localhost:6379/0

# --- 文件存儲 ---
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# --- 阿里云 OSS (当 STORAGE_TYPE=oss 时必填) ---
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET=your-bucket-name

# --- Admin (Vite) ---
# VITE_TRPC_PROXY_TARGET=http://localhost:3000

# --- Web / H5 (Next.js) ---
# NEXT_PUBLIC_TRPC_URL=http://localhost:3000/trpc
# NEXT_PUBLIC_ADMIN_URL=http://localhost:5175

# --- Mobile (Expo) ---
# EXPO_PUBLIC_TRPC_URL=http://localhost:3000/trpc
